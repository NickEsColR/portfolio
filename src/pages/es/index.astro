---
/**
 * es/index.astro
 * Home page (Spanish) — same layout as the English version.
 * Locale is resolved automatically via Astro.currentLocale.
 */
import Layout from "@/layouts/Layout.astro";
import ProfileCard from "@/components/landing/ProfileCard.astro";
import ExperienceSection from "@/components/landing/ExperienceSection.astro";
import ProjectsSection from "@/components/landing/ProjectsSection.astro";
import SkillsSection from "@/components/landing/SkillsSection.astro";
import EducationSection from "@/components/landing/EducationSection.astro";
import CertificatesSection from "@/components/landing/CertificatesSection.astro";
import { useTranslations, getLocale } from "@/i18n/utils";

const locale = getLocale(Astro.currentLocale);
const t = useTranslations(locale);
---

<Layout title={t("meta.title")} description={t("meta.description")}>
  <div
    class="flex flex-1 flex-col overflow-auto bg-transparent px-10 lg:flex-row lg:overflow-hidden"
  >
    <!-- Left column: fixed profile sidebar -->
    <aside class="w-full shrink-0 space-y-6 p-6 lg:w-[30%] lg:p-8">
      <ProfileCard />
    </aside>

    <!-- Right column: scrollable content -->
    <main class="scrollbar-thin flex flex-1 flex-col gap-16 overflow-y-auto p-6">
      <ExperienceSection />
      <ProjectsSection />
      <EducationSection />
      <SkillsSection />
      <CertificatesSection />
    </main>
  </div>
</Layout>
