---
/**
 * ExperienceSection.astro
 * Experience timeline section with all job entries.
 */
import ExperienceItem from "./ExperienceItem.astro";

const experiences = [
  {
    title: "Full-stack Developer",
    company: "Citrux Digital",
    companyUrl: "https://citruxdigital.com",
    location: "COL - Remote",
    period: "2024 - 2025",
    summary: "Developing high-availability full-stack projects.",
    responsibilities: [
      "Developed frontend and backend services using Next.js and Node.js.",
      "Integrated third-party APIs and microservices architecture.",
      "Implemented CI/CD pipelines and automated testing workflows.",
      "Collaborated with cross-functional teams to deliver scalable solutions.",
    ],
    techStack: [
      { name: "Next.js", icon: "◎" },
      { name: "React", icon: "⚛" },
      { name: "Tailwind", icon: "➤" },
      { name: "Node", icon: "◉" },
      { name: "TypeORM", icon: "{ }" },
      { name: "OpenAI", icon: "◎" },
      { name: "AWS", icon: "☁" },
      { name: "Terraform", icon: "◇" },
      { name: "Git", icon: "◈" },
      { name: "GitHub", icon: "◉" },
    ],
  },
  {
    title: "Data Scientist new Associate",
    company: "Accenture",
    companyUrl: "https://accenture.com",
    location: "COL - Remote",
    period: "2023 - 2023",
    summary: "Implement model to optimize client portfolio.",
    responsibilities: [
      "Implement genetic algorithm in Python.",
      "Generate analysis and visualizations using Databricks.",
      "Collaborate with data engineering teams on pipeline development.",
    ],
    techStack: [
      { name: "Python", icon: "🐍" },
      { name: "Databricks", icon: "◈" },
      { name: "Azure DevOps", icon: "☁" },
    ],
  },
];
---

<section id="experience" class="space-y-8">
  <h2 class="text-foreground text-2xl font-bold tracking-tight">Experience</h2>

  <div class="relative space-y-10">
    {
      experiences.map((exp, i) => (
        <div class="flex flex-col gap-1 sm:flex-row sm:gap-8">
          <span class="text-muted-foreground shrink-0 text-sm sm:w-28">{exp.period}</span>
          <div class="flex-1">
            <ExperienceItem
              title={exp.title}
              company={exp.company}
              companyUrl={exp.companyUrl}
              location={exp.location}
              summary={exp.summary}
              responsibilities={exp.responsibilities}
              techStack={exp.techStack}
              isLast={i === experiences.length - 1}
            />
          </div>
        </div>
      ))
    }
  </div>
</section>
