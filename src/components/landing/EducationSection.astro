---
/**
 * EducationSection.astro
 * Education section with degree entries.
 * Fetches education documents from Sanity CMS.
 */
import { sanityClient } from "sanity:client";
import EducationItem from "./EducationItem.astro";
import { formatPeriod } from "@/lib/sanity/utils";
import type { Education } from "@/interfaces/education.interface";

const EDUCATION_QUERY = `*[_type == "education"] | order(startDate desc) { level, degree, institution, startDate, endDate }`;
const education = await sanityClient.fetch<Education[]>(EDUCATION_QUERY);
---

<section id="education" class="space-y-6">
  <h2 class="text-foreground text-2xl font-bold tracking-tight">Education</h2>

  <ol class="space-y-5">
    {
      education.map((edu) => (
        <EducationItem
          level={edu.level}
          degree={edu.degree}
          institution={edu.institution}
          period={formatPeriod(edu.startDate, edu.endDate)}
        />
      ))
    }
  </ol>
</section>
