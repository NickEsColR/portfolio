---
/**
 * ProjectCard.astro
 * Card for a single project with title, description, features, and optional image.
 */
interface Props {
  title: string;
  url?: string;
  githubUrl?: string;
  description: string;
  features: string[];
  image?: string;
}

const { title, url, githubUrl, description, features, image } = Astro.props;
---

<article
  class="border-border bg-card rounded-xl border p-6 shadow-sm transition-shadow hover:shadow-md"
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-card-foreground text-lg font-semibold">
      {
        url ? (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary inline-flex items-center gap-1"
          >
            <svg
              class="text-muted-foreground size-4 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
              <path d="M14 2v4a2 2 0 0 0 2 2h4" />
            </svg>
            {title} <span class="text-xs">↗</span>
          </a>
        ) : (
          <span class="inline-flex items-center gap-1">
            <svg
              class="text-muted-foreground size-4 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
              <path d="M14 2v4a2 2 0 0 0 2 2h4" />
            </svg>
            {title}
          </span>
        )
      }
    </h3>
    {
      githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${title} on GitHub`}
          class="text-muted-foreground hover:text-foreground shrink-0 transition-colors"
        >
          <svg
            class="size-5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
        </a>
      )
    }
  </div>

  <p class="text-muted-foreground mt-2 text-sm">{description}</p>

  {
    features.length > 0 && (
      <ul class="text-muted-foreground mt-3 space-y-1 text-sm">
        {features.map((feature) => (
          <li class="flex items-start gap-2">
            <span class="shrink-0">•</span>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    )
  }

  {
    image && (
      <div class="border-border mt-4 overflow-hidden rounded-lg border">
        <img src={image} alt={title} class="h-auto w-full object-cover" loading="lazy" />
      </div>
    )
  }
</article>
