---
/**
 * ProfileCard.astro
 * Left column: profile photo, name, title, email, social links, and about me.
 */
import EmailBadge from "./EmailBadge.astro";
import SocialLinks from "./SocialLinks.astro";
import type { SocialLink } from "./SocialLinks.astro";

/**
 * Social links data — in a real setup this would come from a CMS
 * (e.g. Sanity, Strapi, Contentful) and each entry would carry its
 * own raw SVG icon stored as a text/code field in the CMS.
 */
const socialLinks: SocialLink[] = [
  {
    href: "mailto:colmenares.ruiz.nicolas@gmail.com",
    label: "Email",
    iconSvg: `<svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    href: "https://www.linkedin.com/in/nickescolr",
    label: "LinkedIn",
    iconSvg: `<svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    href: "https://github.com/NickEsColR",
    label: "GitHub",
    iconSvg: `<svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  },
];
---

<div class="space-y-6 p-6 lg:p-8">
  <!-- Profile photo -->
  <div class="border-border size-20 overflow-hidden rounded-full border-2">
    <img
      src="https://ui-avatars.com/api/?name=Nicolas+Colmenares&size=160&background=6d28d9&color=fff&bold=true"
      alt="Nicolas Colmenares"
      class="size-full object-cover"
      width="80"
      height="80"
    />
  </div>

  <!-- Name & Title -->
  <div>
    <h1 class="text-foreground text-2xl font-bold">Nicolas Colmenares</h1>
    <h3 class="text-muted-foreground text-sm">AI Engineer</h3>
  </div>

  <!-- Email badge -->
  <EmailBadge email="colmenares.ruiz.nicolas@gmail.com" />

  <!-- Social links -->
  <SocialLinks links={socialLinks} />

  <!-- About me -->
  <div class="space-y-3">
    <h2 class="text-foreground text-xl font-bold">About me</h2>
    <p
      class="text-muted-foreground text-sm leading-relaxed text-pretty"
      style="font-family: monospace;"
    >
      Passionate about web development and artificial intelligence. With experience in high impact
      projects, I have developed solutions using NextJS, Astro, Typescript, Python, AWS and Azure.
      My focus is to create scalable and efficient applications that generate real value. Always
      looking for new challenges and learning to keep growing in the technological world.
    </p>
  </div>
</div>
