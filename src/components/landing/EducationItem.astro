---
/**
 * EducationItem.astro
 * Single education entry with degree, institution, and period.
 */
interface Props {
  degree: string;
  institution: string;
  period: string;
}

const { degree, institution, period } = Astro.props;
---

<li class="flex items-start justify-between gap-4">
  <div class="flex items-start gap-3">
    <!-- Graduation cap icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      class="text-muted-foreground mt-0.5 size-5 shrink-0"
      viewBox="0 0 24 24"
      ><path
        d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0zM22 10v6"
      ></path><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"></path></svg
    >
    <div>
      <h4 class="text-foreground font-semibold">{degree}</h4>
      <p class="text-muted-foreground text-sm italic">{institution}</p>
    </div>
  </div>
  <span class="text-muted-foreground shrink-0 text-sm">{period}</span>
</li>
