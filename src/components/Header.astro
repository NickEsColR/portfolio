---
/**
 * Header.astro
 * Site header with logo, search bar placeholder, theme toggle, and language selector.
 */
import ThemeToggle from "./ThemeToggle.astro";
---

<header class="bg-background/80 sticky top-0 z-50 w-full backdrop-blur-md">
  <div class="mx-auto flex h-14 items-center justify-between px-4 sm:px-6">
    <!-- Logo -->
    <a href="/" class="text-foreground hover:text-primary text-sm font-bold transition-colors">
      NickEsColR
    </a>

    <!-- Right side controls -->
    <div class="flex items-center gap-2">
      <!-- Search bar placeholder -->
      <button
        type="button"
        class="border-border bg-secondary/50 text-muted-foreground hover:bg-accent hidden items-center gap-2 rounded-lg border px-3 text-sm transition-colors sm:inline-flex"
        aria-label="Search"
      >
        <span>Search...</span>
        <kbd
          class="border-border bg-background text-muted-foreground pointer-events-none inline-flex h-5 items-center gap-0.5 rounded border px-1.5 font-mono text-9xl text-[10px] font-medium select-none"
        >
          ⌘ K
        </kbd>
      </button>

      <!-- Theme toggle -->
      <ThemeToggle />

      <!-- Language selector placeholder -->
      <button
        type="button"
        class="text-muted-foreground inline-flex cursor-pointer items-center gap-1 rounded-md px-2 py-1.5 text-sm transition-opacity hover:opacity-50"
        aria-label="Change language"
      >
        <svg
          class="size-4"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m5 8 6 6"></path>
          <path d="m4 14 6-6 2-3"></path>
          <path d="M2 5h12"></path>
          <path d="M7 2h1"></path>
          <path d="m22 22-5-10-5 10"></path>
          <path d="M14 18h6"></path>
        </svg>
        <span class="hidden sm:inline">English</span>
        <svg
          class="size-3"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </button>
    </div>
  </div>
</header>
