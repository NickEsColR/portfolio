{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"**/*.{astro,ts,tsx,json,md,css}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.astro": [
      "eslint --fix"
    ],
    "*.{ts,tsx,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sanity/astro": "^3.3.1",
    "@sanity/client": "^7.21.0",
    "@sanity/image-url": "^2.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "astro-icon": "^1.1.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vite": "^7.3.2"
  },
  "pnpm": {
    "overrides": {
      "tar": "7.5.11",
      "picomatch": "4.0.4",
      "follow-redirects": "1.16.0",
      "brace-expansion": "5.0.5"
    }
  }
}
